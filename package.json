{
  "name": "lumen",
  "version": "0.0.1",
  "private": true,
  "main": "index.tsx",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "bundle:web": "npx expo export --platform web",
    "serve:web": "npx serve dist",
    "prebuild:clean": "npx expo prebuild --clean",
    "compile": "tsc --noEmit -p . --pretty",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "depcruise": "depcruise app --config .dependency-cruiser.js",
    "depcruise:graph": "depcruise app --include-only \"^app\" --config .dependency-cruiser.js --output-type dot > app-dependency-graph.dot && dot -T svg app-dependency-graph.dot -o app-dependency-graph.svg && dot -T png app-dependency-graph.dot -o app-dependency-graph.png && rm app-dependency-graph.dot",
    "align-deps": "npx expo install --fix",
    "measure": "flashlight measure",
    "sign": "zipalign -f -v 4 android\\app\\build\\outputs\\apk\\release\\app-release.apk release-signed.apk && apksigner sign --ks lumen.keystore --ks-key-alias lumen release-signed.apk",
    "build": "rmdir /s /q android && npx expo prebuild --platform android && cd android && gradlew assembleRelease",
    "build:ios:sim": "eas build --profile development --platform ios --local",
    "build:ios:device": "eas build --profile development:device --platform ios --local",
    "build:ios:preview": "eas build --profile preview --platform ios --local",
    "build:ios:prod": "eas build --profile production --platform ios --local",
    "build:android:sim": "eas build --profile development --platform android --local",
    "build:android:device": "eas build --profile development:device --platform android --local",
    "build:android:preview": "eas build --profile preview --platform android --local",
    "build:android:prod": "eas build --profile production --platform android --local",
    "adb:connect": "adb connect 192.168.1.104",
    "adb:disconnect": "adb disconnect 192.168.1.104",
    "adb:install:dev": "adb install android/app/build/outputs/apk/release/app-release.apk",
    "adb:install:prod": "adb install release-signed.apk"
  },
  "dependencies": {
    "@bam.tech/lrud": "^8.0.2",
    "@dominicvonk/react-native-apk-installer": "^2.2.2",
    "@expo/metro-runtime": "~6.1.2",
    "@legendapp/list": "^2.0.4",
    "@lodev09/react-native-true-sheet": "^2.0.6",
    "@logicwind/react-native-exit-app": "^0.2.0",
    "@react-native-firebase/analytics": "^23.3.1",
    "@react-native-firebase/app": "^23.3.1",
    "@react-native-firebase/firestore": "^23.3.1",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/elements": "^2.6.4",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.26",
    "date-fns": "^4.1.0",
    "expo": "~54.0.31",
    "expo-application": "^7.0.7",
    "expo-build-properties": "~1.0.9",
    "expo-device": "^8.0.7",
    "expo-haptics": "~15.0.8",
    "expo-image": "^3.0.8",
    "expo-keep-awake": "^15.0.7",
    "expo-linear-gradient": "^15.0.7",
    "expo-linking": "^8.0.8",
    "expo-localization": "~17.0.7",
    "expo-navigation-bar": "^5.0.8",
    "expo-network": "^8.0.7",
    "expo-screen-orientation": "^9.0.7",
    "expo-speech-recognition": "^2.1.2",
    "expo-splash-screen": "^31.0.10",
    "expo-status-bar": "^3.0.8",
    "expo-system-ui": "~6.0.7",
    "expo-video": "~2.2.2",
    "html-entities": "^2.6.0",
    "i18next": "^23.14.0",
    "intl-pluralrules": "^2.0.1",
    "lucide-react-native": "^0.544.0",
    "moment": "^2.30.1",
    "node-html-parser": "^7.0.1",
    "node-webvtt": "^1.9.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^15.0.1",
    "react-moment": "^1.1.3",
    "react-native": "npm:react-native-tvos@0.81.5-2",
    "react-native-awesome-slider": "^2.9.0",
    "react-native-blob-util": "^0.22.2",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gradient-shimmer": "^2.2.0",
    "react-native-keyboard-controller": "^1.20.7",
    "react-native-keyevent": "^0.3.2",
    "react-native-mmkv": "^3.3.1",
    "react-native-nitro-modules": "^0.31.10",
    "react-native-pager-view": "^7.0.0",
